{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Furniture product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "material": { "type": "string" },
        "deliveryTimeline": { "type": "string" },
        "images": { "type": "array" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "price", "category", "description", "images"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "shippingAddress": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["items", "total", "paymentMethod", "customerEmail", "customerPhone", "shippingAddress", "status", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer contact message",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "All products in the store"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "All customer orders"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Customer inquiries from the contact form"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Authorized administrators (doc ID is UID)"
    }
  }
}
