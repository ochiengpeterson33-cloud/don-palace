rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || request.auth.token.email == 'ochiengpeterson33@gmail.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- PRODUCTS ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'description', 'images', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 150
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() <= 50
        && data.description is string && data.description.size() <= 2000
        && data.images is list && data.images.size() >= 0 && data.images.size() <= 10
        && (data.images.size() == 0 || data.images[0] is string)
        && data.createdAt == request.time
        && (!('material' in data) || (data.material is string && data.material.size() <= 100))
        && (!('deliveryTimeline' in data) || (data.deliveryTimeline is string && data.deliveryTimeline.size() <= 100));
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && incoming().createdAt == existing().createdAt && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'price', 'category', 'description', 'images', 'material', 'deliveryTimeline', 'updatedAt'
        ])
      ) && incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    // --- ORDERS (Public Create, Admin Read/Update) ---
    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'total', 'paymentMethod', 'customerEmail', 'customerPhone', 'shippingAddress', 'status', 'createdAt'])
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.total is number && data.total >= 0
        && data.paymentMethod is string && data.paymentMethod.size() <= 50
        && data.customerEmail is string && data.customerEmail.size() <= 100
        && data.customerPhone is string && data.customerPhone.size() <= 20
        && data.shippingAddress is string && data.shippingAddress.size() <= 500
        && data.status in ['pending', 'processing', 'completed', 'cancelled']
        && (!('userId' in data) || (data.userId is string && data.userId.size() <= 128));
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      // Public creation allowed for guest checkout
      allow create: if isValidOrder(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && incoming().createdAt == existing().createdAt && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      ) && incoming().updatedAt == request.time;
    }

    // --- INQUIRIES (Public Create, Admin Read/Update) ---
    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 20));
    }

    match /inquiries/{inquiryId} {
      allow read: if isAdmin();
      allow create: if isValidInquiry(incoming()) && incoming().createdAt == request.time;
      allow delete: if isAdmin();
    }

    // --- ADMINS ---
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId || isAdmin();
      allow write: if false; // Only manageable via Firebase Console
    }
  }
}
